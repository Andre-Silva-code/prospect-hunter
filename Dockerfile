# ---- deps ----
FROM node:20-slim AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

# ---- builder ----
FROM node:20-slim AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ENV NEXT_TELEMETRY_DISABLED=1

# Recebe todas as variáveis como build args para o next.config.mjs embutir no bundle
ARG SUPABASE_URL
ARG SUPABASE_ANON_KEY
ARG SUPABASE_SERVICE_ROLE_KEY
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY
ARG NEXTAUTH_URL
ARG NEXTAUTH_SECRET
ARG APIFY_TOKEN
ARG APIFY_API_BASE_URL
ARG PROSPECT_APIFY_INSTAGRAM_TASK_ID
ARG PROSPECT_APIFY_INSTAGRAM_ACTOR_ID
ARG PROSPECT_APIFY_LINKEDIN_TASK_ID
ARG PROSPECT_APIFY_LINKEDIN_ACTOR_ID
ARG PROSPECT_APIFY_GOOGLE_MAPS_TASK_ID
ARG PROSPECT_APIFY_GOOGLE_MY_BUSINESS_TASK_ID
ARG GEMINI_API_KEY
ARG GEMINI_API_BASE_URL
ARG GEMINI_MODEL
ARG GOOGLE_MAPS_API_KEY
ARG UAZAPI_API_URL
ARG UAZAPI_INSTANCE_ID
ARG UAZAPI_API_TOKEN
ARG OUTREACH_CRON_SECRET
ARG OUTREACH_DELAY_MS
ARG OUTREACH_MIN_SCORE
ARG OWNER_PHONE
ARG ENABLE_LOCAL_AUTH
ARG LOCAL_AUTH_EMAIL
ARG LOCAL_AUTH_PASSWORD
ARG LOCAL_AUTH_NAME
ARG LEADS_STORAGE_PROVIDER
ARG USE_LOCAL_STORAGE
ARG PROSPECTING_ENABLE_DEMO_FALLBACK

# Expõe os ARGs como ENV para que o next.config.mjs leia via process.env durante o build
ENV SUPABASE_URL=$SUPABASE_URL
ENV SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY
ENV SUPABASE_SERVICE_ROLE_KEY=$SUPABASE_SERVICE_ROLE_KEY
ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV NEXTAUTH_URL=$NEXTAUTH_URL
ENV NEXTAUTH_SECRET=$NEXTAUTH_SECRET
ENV APIFY_TOKEN=$APIFY_TOKEN
ENV APIFY_API_BASE_URL=$APIFY_API_BASE_URL
ENV PROSPECT_APIFY_INSTAGRAM_TASK_ID=$PROSPECT_APIFY_INSTAGRAM_TASK_ID
ENV PROSPECT_APIFY_INSTAGRAM_ACTOR_ID=$PROSPECT_APIFY_INSTAGRAM_ACTOR_ID
ENV PROSPECT_APIFY_LINKEDIN_TASK_ID=$PROSPECT_APIFY_LINKEDIN_TASK_ID
ENV PROSPECT_APIFY_LINKEDIN_ACTOR_ID=$PROSPECT_APIFY_LINKEDIN_ACTOR_ID
ENV PROSPECT_APIFY_GOOGLE_MAPS_TASK_ID=$PROSPECT_APIFY_GOOGLE_MAPS_TASK_ID
ENV PROSPECT_APIFY_GOOGLE_MY_BUSINESS_TASK_ID=$PROSPECT_APIFY_GOOGLE_MY_BUSINESS_TASK_ID
ENV GEMINI_API_KEY=$GEMINI_API_KEY
ENV GEMINI_API_BASE_URL=$GEMINI_API_BASE_URL
ENV GEMINI_MODEL=$GEMINI_MODEL
ENV GOOGLE_MAPS_API_KEY=$GOOGLE_MAPS_API_KEY
ENV UAZAPI_API_URL=$UAZAPI_API_URL
ENV UAZAPI_INSTANCE_ID=$UAZAPI_INSTANCE_ID
ENV UAZAPI_API_TOKEN=$UAZAPI_API_TOKEN
ENV OUTREACH_CRON_SECRET=$OUTREACH_CRON_SECRET
ENV OUTREACH_DELAY_MS=$OUTREACH_DELAY_MS
ENV OUTREACH_MIN_SCORE=$OUTREACH_MIN_SCORE
ENV OWNER_PHONE=$OWNER_PHONE
ENV ENABLE_LOCAL_AUTH=$ENABLE_LOCAL_AUTH
ENV LOCAL_AUTH_EMAIL=$LOCAL_AUTH_EMAIL
ENV LOCAL_AUTH_PASSWORD=$LOCAL_AUTH_PASSWORD
ENV LOCAL_AUTH_NAME=$LOCAL_AUTH_NAME
ENV LEADS_STORAGE_PROVIDER=$LEADS_STORAGE_PROVIDER
ENV USE_LOCAL_STORAGE=$USE_LOCAL_STORAGE
ENV PROSPECTING_ENABLE_DEMO_FALLBACK=$PROSPECTING_ENABLE_DEMO_FALLBACK

RUN npm run build

# ---- runner ----
FROM node:20-slim AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

COPY --from=builder /app/node_modules/pdfkit/js/data ./node_modules/pdfkit/js/data
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

RUN mkdir -p /app/data

EXPOSE 3000
CMD ["node", "server.js"]

{
  "regions": ["sfo1"],
  "env": [
    "SUPABASE_URL",
    "SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL",
    "APIFY_TOKEN",
    "GEMINI_API_KEY",
    "REDIS_URL",
    "SENTRY_DSN",
    "UAZAPI_API_URL",
    "UAZAPI_API_TOKEN",
    "UAZAPI_INSTANCE_ID",
    "OUTREACH_CRON_SECRET",
    "UAZAPI_WEBHOOK_SECRET"
  ],
  "crons": [
    {
      "path": "/api/outreach/process",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/outreach/follow-up",
      "schedule": "0 13 * * *"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm ci"
}

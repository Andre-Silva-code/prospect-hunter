# Supabase Configuration
# Get from your Supabase project settings
SUPABASE_URL=https://[project-id].supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
NEXT_PUBLIC_SUPABASE_URL=https://[project-id].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Storage mode
# Em produção, SUPABASE_URL e SUPABASE_ANON_KEY são obrigatórios.
# Para desenvolvimento local sem Supabase, defina USE_LOCAL_STORAGE=true.
USE_LOCAL_STORAGE=false

# NextAuth Configuration
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Apify API Token
# Get from: https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_...

# Google Gemini API Key
# Get from: https://console.cloud.google.com
GEMINI_API_KEY=AIza...
GOOGLE_MAPS_API_KEY=AIza...

# Redis/Cache Configuration
# For local development: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Sentry (Error Tracking)
# Optional - Get from: https://sentry.io
SENTRY_DSN=https://...

# Local Auth (development fallback)
# Enabled automatically in non-production environments
ENABLE_LOCAL_AUTH=false
LOCAL_AUTH_EMAIL=admin@prospecthunter.local
LOCAL_AUTH_PASSWORD=prospect123
LOCAL_AUTH_NAME=Operador Local
NEXT_PUBLIC_LOCAL_AUTH_EMAIL=admin@prospecthunter.local
NEXT_PUBLIC_LOCAL_AUTH_PASSWORD=prospect123
NEXT_PUBLIC_ENABLE_LOCAL_AUTH_HINT=true

# Prospecting Connectors (optional)
# Configure webhook-style connectors for Instagram and LinkedIn prospecting.
# These connectors must accept POST JSON with: source, icp, niche, region, limit
# and return an array of leads.
PROSPECT_CONNECTOR_INSTAGRAM_URL=
PROSPECT_CONNECTOR_LINKEDIN_URL=
PROSPECT_CONNECTOR_TOKEN=

# Apify native integration for prospecting
# Prefer configuring TASK IDs (best for custom actor inputs).
# If TASK ID is not provided, ACTOR ID can be used with default input payload.
APIFY_API_BASE_URL=https://api.apify.com
PROSPECT_APIFY_INSTAGRAM_TASK_ID=
PROSPECT_APIFY_LINKEDIN_TASK_ID=
PROSPECT_APIFY_INSTAGRAM_ACTOR_ID=
PROSPECT_APIFY_LINKEDIN_ACTOR_ID=
PROSPECT_APIFY_GOOGLE_MAPS_TASK_ID=
PROSPECT_APIFY_GOOGLE_MY_BUSINESS_TASK_ID=
PROSPECT_APIFY_GOOGLE_MAPS_ACTOR_ID=
PROSPECT_APIFY_GOOGLE_MY_BUSINESS_ACTOR_ID=

# Uazapi WhatsApp API (outreach automático GMN)
# Get from: https://www.uazapi.com/
UAZAPI_API_URL=https://api.uazapi.com
UAZAPI_API_TOKEN=
UAZAPI_INSTANCE_ID=
UAZAPI_RATE_LIMIT_MAX=10
UAZAPI_RATE_LIMIT_WINDOW_MS=300000
UAZAPI_WEBHOOK_SECRET=

# Outreach automation
OUTREACH_CRON_SECRET=
OUTREACH_BRAND_NAME=Prospect Hunter
OUTREACH_BRAND_COLOR=#a04b2c
